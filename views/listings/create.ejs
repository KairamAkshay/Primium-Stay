<%- include('../partials/header') %>

<div style="max-width: 800px; margin: 0 auto;">
    <h2 style="margin-bottom: 2rem;"><i class="fa-solid fa-plus-circle"></i> Create New Listing</h2>

    <div class="glass-card">
        <form action="/listings/create" method="POST" enctype="multipart/form-data">
            
            <div class="form-group">
                <label class="form-label" for="title">Title <span style="color: var(--danger);">*</span></label>
                <input type="text" id="title" name="title" class="form-control" required placeholder="Luxury Beachhouse in Malibu">
            </div>
            
            <div class="form-group">
                <label class="form-label" for="location">Location <span style="color: var(--danger);">*</span></label>
                <input type="text" id="location" name="location" class="form-control" required placeholder="Malibu, CA">
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label" for="price">Price per night ($) <span style="color: var(--danger);">*</span></label>
                    <input type="number" id="price" name="price" class="form-control" required min="0" placeholder="150">
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="amenities">Amenities (Comma separated)</label>
                    <input type="text" id="amenities" name="amenities" class="form-control" placeholder="Wifi, Pool, Ocean View">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="description">Description <span style="color: var(--danger);">*</span></label>
                <textarea id="description" name="description" class="form-control" required rows="6" placeholder="Describe your property..."></textarea>
            </div>
            
            <div class="form-group">
                <label class="form-label" for="images">Images (Max 5, Image files only)</label>
                <div style="background: rgba(0,0,0,0.2); padding: 1.5rem; border: 1px dashed var(--border-color); border-radius: 8px; text-align: center;">
                    <i class="fa-solid fa-cloud-arrow-up fa-2x" style="color: var(--primary); margin-bottom: 1rem;"></i>
                    <input type="file" id="images" name="images" class="form-control" multiple style="border: none; background: transparent;">
                </div>
            </div>

            <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2rem;">
                <a href="/dashboard" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem;">Publish Listing</button>
            </div>
            
        </form>
    </div>
</div>

<%- include('../partials/footer') %>
