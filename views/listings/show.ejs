<%- include('../partials/header') %>

<div style="max-width: 1000px; margin: 0 auto; padding-bottom: 4rem;">
    <!-- Gallery -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem; margin-bottom: 2rem; border-radius: 20px; overflow: hidden; height: 400px;">
        <% if(listing.images && listing.images.length > 0) { %>
            <div style="height: 100%;">
                <img src="<%= listing.images[0] %>" alt="Cover" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div style="display: grid; grid-template-rows: 1fr 1fr; gap: 1rem;">
                <% if(listing.images[1]) { %>
                    <img src="<%= listing.images[1] %>" style="width: 100%; height: 100%; object-fit: cover;">
                <% } else { %>
                    <div style="background: #1e293b; height: 100%;"></div>
                <% } %>
                
                <% if(listing.images[2]) { %>
                    <img src="<%= listing.images[2] %>" style="width: 100%; height: 100%; object-fit: cover;">
                <% } else { %>
                    <div style="background: #1e293b; height: 100%;"></div>
                <% } %>
            </div>
        <% } else { %>
            <div style="grid-column: 1 / -1; background: #1e293b; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                <h2><i class="fa-solid fa-image"></i> No Images Available</h2>
            </div>
        <% } %>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 3rem;">
        <!-- Listing Info -->
        <div>
            <div style="margin-bottom: 2rem; border-bottom: var(--glass-border); padding-bottom: 2rem;">
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;"><%= listing.title %></h1>
                <p style="color: var(--text-muted); font-size: 1.1rem;"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></p>
                <div style="margin-top: 1rem; display: flex; align-items: center; gap: 1rem;">
                    <div style="width: 40px; height: 40px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                        <%= listing.provider.name.charAt(0) %>
                    </div>
                    <div>
                        <p style="font-weight: 500;">Hosted by <%= listing.provider.name %></p>
                        <p style="font-size: 0.85rem; color: var(--text-muted);"><%= listing.provider.email %></p>
                    </div>
                </div>
            </div>

            <div style="margin-bottom: 2rem; border-bottom: var(--glass-border); padding-bottom: 2rem;">
                <h3 style="margin-bottom: 1rem;">About this space</h3>
                <p style="color: var(--text-muted); line-height: 1.7; white-space: pre-line;"><%= listing.description %></p>
            </div>

            <div>
                <h3 style="margin-bottom: 1rem;">Amenities</h3>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
                    <% listing.amenities.forEach(amenity => { %>
                        <div style="display: flex; align-items: center; gap: 0.8rem; color: var(--text-muted);">
                            <i class="fa-solid fa-check" style="color: var(--success);"></i> <%= amenity %>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Booking Box -->
        <div>
            <div class="glass-card" style="position: sticky; top: 100px;">
                <div style="margin-bottom: 1.5rem;">
                    <span style="font-size: 2rem; font-weight: 700; color: var(--primary);">$<%= listing.price %></span> 
                    <span style="color: var(--text-muted);">/ night</span>
                </div>

                <% if(user) { %>
                    <form action="/bookings" method="POST">
                        <input type="hidden" name="listingId" value="<%= listing._id %>">
                        
                        <div class="form-group">
                            <label class="form-label" for="checkIn">Check-in</label>
                            <input type="date" id="checkIn" name="checkIn" class="form-control" required style="background: rgba(0,0,0,0.3);">
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label" for="checkOut">Check-out</label>
                            <input type="date" id="checkOut" name="checkOut" class="form-control" required style="background: rgba(0,0,0,0.3);">
                        </div>
                        
                        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-top: 1rem; background: linear-gradient(to right, var(--primary), var(--accent));">
                            Reserve
                        </button>
                        <p style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-top: 1rem;">You won't be charged yet.</p>
                    </form>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-primary" style="width: 100%; text-align: center; padding: 1rem; display: block;">Log in to book</a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
