<%- include('../partials/header') %>

<h2 style="margin-bottom: 2rem;"><i class="fa-solid fa-suitcase-rolling"></i> My Trips</h2>

<div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
    <table>
        <thead>
            <tr>
                <th>Property</th>
                <th>Dates</th>
                <th>Total Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if(bookings && bookings.length > 0) { %>
                <% bookings.forEach(booking => { %>
                    <tr>
                        <td style="font-weight: 500;">
                            <% if(booking.listing) { %>
                                <a href="/listings/<%= booking.listing._id %>" style="color: var(--primary); text-decoration: none;"><%= booking.listing.title %></a>
                            <% } else { %>
                                <span style="color: var(--text-muted);">Listing Unavailable</span>
                            <% } %>
                        </td>
                        <td>
                            <%= new Date(booking.checkIn).toLocaleDateString() %> - <%= new Date(booking.checkOut).toLocaleDateString() %>
                        </td>
                        <td style="font-weight: 700; color: var(--success);">$<%= booking.totalPrice.toFixed(2) %></td>
                        <td><span class="badge badge-<%= booking.status %>"><%= booking.status %></span></td>
                        <td>
                            <% if(booking.status === 'confirmed') { %>
                                <form action="/bookings/cancel/<%= booking._id %>" method="POST" style="margin: 0;">
                                    <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.8rem; font-size: 0.8rem;">Cancel Booking</button>
                                </form>
                            <% } else { %>
                                <span style="font-size: 0.8rem; color: var(--text-muted);"><i class="fa-solid fa-ban"></i> Action Disabled</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 2rem;">
                        You haven't booked any trips yet. <a href="/listings" style="color: var(--primary);">Explore places to stay!</a>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
