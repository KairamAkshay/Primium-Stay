<%- include('../partials/header') %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2><i class="fa-solid fa-users-gear"></i> User Management (Admin)</h2>
</div>

<div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
    <table>
        <thead>
            <tr>
                <th><i class="fa-solid fa-user"></i> Name</th>
                <th><i class="fa-solid fa-envelope"></i> Email</th>
                <th><i class="fa-solid fa-shield"></i> Role</th>
                <th><i class="fa-solid fa-calendar"></i> Joined</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if(users && users.length > 0) { %>
                <% users.forEach(u => { %>
                    <tr>
                        <td style="font-weight: 500;"><%= u.name %></td>
                        <td style="color: var(--text-muted);"><%= u.email %></td>
                        <td>
                            <form action="/users/role/<%= u._id %>" method="POST" style="display: flex; gap: 0.5rem; align-items: center;">
                                <select name="role" class="form-control" style="padding: 0.3rem; margin: 0; min-width: 110px; font-size: 0.9rem;" 
                                    onchange="this.form.submit()" <%= user._id.toString() === u._id.toString() ? 'disabled' : '' %>>
                                    <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                                    <option value="provider" <%= u.role === 'provider' ? 'selected' : '' %>>Provider</option>
                                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                </select>
                            </form>
                        </td>
                        <td style="font-size: 0.9rem; color: var(--text-muted);"><%= new Date(u.createdAt).toLocaleDateString() %></td>
                        <td>
                            <% if(user._id.toString() !== u._id.toString()) { %>
                                <form action="/users/<%= u._id %>?_method=DELETE" method="POST" style="margin: 0;">
                                    <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.8rem; font-size: 0.8rem;"><i class="fa-solid fa-trash"></i> Delete</button>
                                </form>
                            <% } else { %>
                                <span class="badge badge-role">You</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
